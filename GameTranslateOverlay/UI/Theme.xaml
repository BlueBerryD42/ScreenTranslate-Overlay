<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="HudBackgroundColor">#0A0A0B</Color>
    <Color x:Key="HudAccentColor">#5B8EF0</Color>
    <Color x:Key="HudTextColor">#F5F5F7</Color>
    <Color x:Key="HudMutedColor">#9CA3AF</Color>
    <Color x:Key="HudSecondaryButtonColor">#2A2A2E</Color>
    <Color x:Key="HudSecondaryButtonHoverColor">#3A3A42</Color>
    <Color x:Key="HudAccentHoverColor">#4A7EE0</Color>

    <SolidColorBrush x:Key="HudBackgroundBrush" Color="{StaticResource HudBackgroundColor}" />
    <SolidColorBrush x:Key="HudAccentBrush" Color="{StaticResource HudAccentColor}" />
    <SolidColorBrush x:Key="HudTextBrush" Color="{StaticResource HudTextColor}" />
    <SolidColorBrush x:Key="HudMutedBrush" Color="{StaticResource HudMutedColor}" />
    <SolidColorBrush x:Key="HudSecondaryButtonBrush" Color="{StaticResource HudSecondaryButtonColor}" />
    <SolidColorBrush x:Key="HudSecondaryButtonHoverBrush" Color="{StaticResource HudSecondaryButtonHoverColor}" />
    <SolidColorBrush x:Key="HudAccentHoverBrush" Color="{StaticResource HudAccentHoverColor}" />

    <FontFamily x:Key="UiFontFamily">Segoe UI, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Cascadia Mono, Consolas, Courier New, monospace</FontFamily>

    <Style x:Key="HudPillBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HudBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HudAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="14,10" />
    </Style>

    <Style x:Key="SettingsWindowStyle" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource HudBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Margin" Value="0,6,0,4" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudMutedBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style x:Key="ColorSwatchStyle" TargetType="Border">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="BorderBrush" Value="#555558" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="#FFFFFF" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style x:Key="HudTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#151518" />
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="BorderBrush" Value="#2A2A2E" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Height" Value="28" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="#151518" />
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="BorderBrush" Value="#2A2A2E" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Height" Value="28" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <ControlTemplate x:Key="HudComboBoxToggleButtonTemplate" TargetType="ToggleButton">
        <Border x:Name="toggleBorder"
                Background="White"
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,0"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Path x:Name="arrow"
                      Grid.Column="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="#555555"
                      Stretch="Uniform"
                      Width="8"
                      Height="5" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="toggleBorder" Property="Background" Value="#F5F5F5" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="toggleBorder" Property="Background" Value="#F0F0F0" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="arrow" Property="Fill" Value="#AAAAAA" />
                <Setter TargetName="toggleBorder" Property="Opacity" Value="0.6" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="HudComboBoxTemplate" TargetType="ComboBox">
        <Border x:Name="MainBorder"
                Background="White"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                SnapsToDevicePixels="True">
        <Grid SnapsToDevicePixels="True">
            <ToggleButton x:Name="ToggleButton"
                          Focusable="False"
                          ClickMode="Press"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                          Template="{StaticResource HudComboBoxToggleButtonTemplate}" />
            <ContentPresenter x:Name="ContentSite"
                              IsHitTestVisible="False"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                              Margin="8,0,24,0"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              TextElement.Foreground="#111111" />
            <TextBox x:Name="PART_EditableTextBox"
                     Style="{x:Null}"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     Margin="8,0,24,0"
                     Focusable="True"
                     Background="Transparent"
                     Visibility="Hidden"
                     IsReadOnly="{TemplateBinding IsReadOnly}"
                     TextElement.Foreground="#111111" />
            <Popup x:Name="Popup"
                   Placement="Bottom"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True"
                   Focusable="False"
                   PopupAnimation="Slide">
                <Grid x:Name="DropDown"
                      SnapsToDevicePixels="True"
                      MinWidth="{TemplateBinding ActualWidth}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                    <Border x:Name="DropDownBorder"
                            Background="White"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            CornerRadius="0">
                        <ScrollViewer Margin="0"
                                      SnapsToDevicePixels="True"
                                      CanContentScroll="True">
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Popup>
        </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="HasItems" Value="False">
                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#888888" />
                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#888888" />
            </Trigger>
            <Trigger Property="IsGrouping" Value="True">
                <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            </Trigger>
            <Trigger Property="IsEditable" Value="True">
                <Setter Property="IsTabStop" Value="False" />
                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="HudComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="#111111" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#E8EEFC" />
                            <Setter Property="Foreground" Value="#111111" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#AAAAAA" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="#111111" />
        <Setter Property="BorderBrush" Value="#CCCCCC" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Height" Value="28" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource HudComboBoxItemStyle}" />
        <Setter Property="Template" Value="{StaticResource HudComboBoxTemplate}" />
    </Style>

    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource HudComboBoxItemStyle}" />

    <ControlTemplate x:Key="PrimaryButtonTemplate" TargetType="Button">
        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" TextElement.Foreground="{TemplateBinding Foreground}" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource HudAccentHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource HudAccentHoverBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="Opacity" Value="0.5" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="SecondaryButtonTemplate" TargetType="Button">
        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" TextElement.Foreground="{TemplateBinding Foreground}" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource HudSecondaryButtonHoverBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource HudSecondaryButtonHoverBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="Opacity" Value="0.5" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource HudAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template" Value="{StaticResource PrimaryButtonTemplate}" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource HudSecondaryButtonBrush}" />
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template" Value="{StaticResource SecondaryButtonTemplate}" />
    </Style>

    <ControlTemplate x:Key="SecondaryToggleButtonTemplate" TargetType="ToggleButton">
        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" TextElement.Foreground="{TemplateBinding Foreground}" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource HudSecondaryButtonHoverBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource HudSecondaryButtonHoverBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource HudAccentBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="Opacity" Value="0.5" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="SecondaryToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource HudSecondaryButtonBrush}" />
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template" Value="{StaticResource SecondaryToggleButtonTemplate}" />
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}" />

    <ControlTemplate x:Key="HudSliderThumbTemplate" TargetType="Thumb">
        <Border x:Name="thumb"
                Width="14"
                Height="14"
                Background="White"
                BorderBrush="#555555"
                BorderThickness="1"
                CornerRadius="7"
                VerticalAlignment="Center" />
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="thumb" Property="Width" Value="16" />
                <Setter TargetName="thumb" Property="Height" Value="16" />
                <Setter TargetName="thumb" Property="CornerRadius" Value="8" />
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="thumb" Property="Width" Value="16" />
                <Setter TargetName="thumb" Property="Height" Value="16" />
                <Setter TargetName="thumb" Property="CornerRadius" Value="8" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="HudSliderThumbStyle" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template" Value="{StaticResource HudSliderThumbTemplate}" />
    </Style>

    <ControlTemplate x:Key="HudSliderDecreaseButtonTemplate" TargetType="RepeatButton">
        <Border Background="{TemplateBinding Background}"
                Height="4"
                CornerRadius="2,0,0,2"
                VerticalAlignment="Center" />
    </ControlTemplate>

    <ControlTemplate x:Key="HudSliderIncreaseButtonTemplate" TargetType="RepeatButton">
        <Border Background="Transparent" Height="32" VerticalAlignment="Center" />
    </ControlTemplate>

    <ControlTemplate x:Key="HudSliderTemplate" TargetType="Slider">
        <Grid MinHeight="32" VerticalAlignment="Center">
            <Border Height="4"
                    VerticalAlignment="Center"
                    Background="#2A2A2E"
                    CornerRadius="2"
                    Margin="7,0" />
            <Track x:Name="PART_Track" VerticalAlignment="Center">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="Slider.DecreaseLarge">
                        <RepeatButton.Style>
                            <Style TargetType="RepeatButton">
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="Background" Value="{StaticResource HudAccentBrush}" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="IsTabStop" Value="False" />
                                <Setter Property="Template" Value="{StaticResource HudSliderDecreaseButtonTemplate}" />
                            </Style>
                        </RepeatButton.Style>
                    </RepeatButton>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="Slider.IncreaseLarge">
                        <RepeatButton.Style>
                            <Style TargetType="RepeatButton">
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="IsTabStop" Value="False" />
                                <Setter Property="Template" Value="{StaticResource HudSliderIncreaseButtonTemplate}" />
                            </Style>
                        </RepeatButton.Style>
                    </RepeatButton>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource HudSliderThumbStyle}" />
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource HudAccentBrush}" />
        <Setter Property="Height" Value="32" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource HudSliderTemplate}" />
    </Style>

    <Style TargetType="Expander">
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Margin" Value="0,4,0,4" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource HudTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="Margin" Value="0,2,0,2" />
    </Style>
</ResourceDictionary>
