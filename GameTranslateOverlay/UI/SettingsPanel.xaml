<Window x:Class="GameTranslateOverlay.UI.SettingsPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="340"
        MaxHeight="480"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource SettingsWindowStyle}"
        ResizeMode="NoResize">
    <Window.Resources>
        <DataTemplate x:Key="LangItemTemplate">
            <TextBlock Text="{Binding Label}" Foreground="#111111" FontFamily="{StaticResource UiFontFamily}" FontSize="12" />
        </DataTemplate>
    </Window.Resources>
    <Border Padding="6" Background="{StaticResource HudBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="GameTranslateOverlay" Style="{StaticResource HudTextBlockStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />

                    <TextBlock Text="Translation" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="DeepL API key" Style="{StaticResource FieldLabelStyle}" />
                    <PasswordBox x:Name="ApiKeyBox" Margin="0,0,0,4" />
                    <Button Content="Test API" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Margin="0,0,0,4" Click="OnTestApiClick" />
                    <TextBlock Text="DeepL quota" Style="{StaticResource FieldLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="QuotaStatusText" TextWrapping="Wrap" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock x:Name="RefreshQuotaLink" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11" Cursor="Hand" TextDecorations="Underline" Foreground="#2563EB" MouseLeftButtonUp="OnRefreshQuotaClick">
                            <Run Text="Refresh" />
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="Source language" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="SourceLangCombo" Margin="0,0,0,4" SelectionChanged="OnSourceLangChanged" ItemTemplate="{StaticResource LangItemTemplate}" />

                    <TextBlock Text="Target language" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox x:Name="TargetLangCombo" Margin="0,0,0,6" ItemTemplate="{StaticResource LangItemTemplate}" />
                    <TextBlock Text="Windows OCR status" Style="{StaticResource FieldLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock x:Name="OcrStatusText" TextWrapping="Wrap" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock x:Name="OcrSettingsLink" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11" Cursor="Hand" TextDecorations="Underline" Foreground="#2563EB" Visibility="Collapsed" MouseLeftButtonUp="OnOcrSettingsLinkClick">
                            <Run Text="Open Language settings" />
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="Hotkeys" Style="{StaticResource SectionHeaderStyle}" />
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Translate" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="0" x:Name="TranslateHotkeyBox" Margin="0,0,0,0" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Pick region" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="2" x:Name="PickRegionHotkeyBox" />
                    </Grid>
                    <TextBlock Text="Overlay" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="Text color" Style="{StaticResource FieldLabelStyle}" />
                    <DockPanel Margin="0,0,0,4">
                        <Button Content="Pick" Style="{StaticResource SecondaryButtonStyle}" DockPanel.Dock="Right" Margin="6,0,0,0" Click="PickTextColor" />
                        <Border x:Name="TextColorSwatch" Style="{StaticResource ColorSwatchStyle}" DockPanel.Dock="Left" />
                        <TextBlock x:Name="TextColorHexLabel" Style="{StaticResource HudTextBlockStyle}" VerticalAlignment="Center" FontFamily="{StaticResource MonoFontFamily}" FontSize="11" Margin="0,0,6,0" />
                    </DockPanel>

                    <TextBlock Text="Background color" Style="{StaticResource FieldLabelStyle}" />
                    <DockPanel Margin="0,0,0,4">
                        <Button Content="Pick" Style="{StaticResource SecondaryButtonStyle}" DockPanel.Dock="Right" Margin="6,0,0,0" Click="PickBackgroundColor" />
                        <Border x:Name="BackgroundColorSwatch" Style="{StaticResource ColorSwatchStyle}" DockPanel.Dock="Left" />
                        <TextBlock x:Name="BackgroundColorHexLabel" Style="{StaticResource HudTextBlockStyle}" VerticalAlignment="Center" FontFamily="{StaticResource MonoFontFamily}" FontSize="11" Margin="0,0,6,0" />
                    </DockPanel>

                    <TextBlock Text="Background opacity" Style="{StaticResource FieldLabelStyle}" />
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock x:Name="OpacityLabel" DockPanel.Dock="Right" Width="36" TextAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource HudMutedBrush}" />
                        <Slider x:Name="OpacitySlider" Minimum="0.5" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" />
                    </DockPanel>

                    <TextBlock Text="Font size (10-14)" Style="{StaticResource FieldLabelStyle}" />
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock x:Name="FontSizeLabel" Style="{StaticResource HudTextBlockStyle}" DockPanel.Dock="Right" Width="28" TextAlignment="Right" VerticalAlignment="Center" />
                        <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="14" TickFrequency="1" IsSnapToTickEnabled="True" />
                    </DockPanel>

                    <TextBlock Text="Auto-hide (seconds, 0 = off)" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox x:Name="AutoHideBox" Margin="0,0,0,6" />

                    <TextBlock Text="General" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="Log file" Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock x:Name="LogPathText" TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource HudMutedBrush}" Margin="0,0,0,4" />
                    <Button Content="Open log folder" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left" Margin="0,0,0,4" Click="OnOpenLogFolderClick" />
                    <CheckBox x:Name="StartWithWindowsBox" Content="Start with Windows" Margin="0,0,0,4" />
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                <Button Content="Reset defaults" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Click="OnResetClick" />
                <Button Content="Cancel" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Click="OnCancelClick" />
                <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Click="OnSaveClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>


